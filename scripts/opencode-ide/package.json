{
  "name": "opencode-ide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Antigravity-style native shell around opencode. Vite + React + shadcn/ui. Wraps opencode serve via local HTTP API.",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview --port 5173",
    "start": "electron ."
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14",
